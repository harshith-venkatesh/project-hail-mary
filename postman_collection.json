          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/00000000-0000-4000-a000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "00000000-0000-4000-a000-000000000000"]
            }
          },
          "response": []
        },
        {
          "name": "Update user name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Name updated', () => pm.expect(pm.response.json().data.name).to.eql('Alice Updated'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Alice Updated\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{userId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status is 204', () => pm.response.to.have.status(204));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{userId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Send message (happy path)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Status defaults to sent', () => pm.expect(pm.response.json().data.status).to.eql('sent'));",
                  "pm.collectionVariables.set('messageId', pm.response.json().data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"{{userId2}}\",\n  \"receiverId\": \"{{userId}}\",\n  \"content\": \"Hello Alice!\"\n}"
